# 复制到 shell 或 CI 密钥库后执行：bash scripts/cron-budget-risks.sh [threshold]
# 与 GET /api/v1/admin/campaigns/budget-risks 一致；命中风险活动时可 POST 到 Webhook

AIADS_ADMIN_API=http://localhost:8080/api/v1/admin
AIADS_ADMIN_TOKEN=

# 可选：有命中项（count>0）时向该 URL POST JSON（脚本内已组装 source/threshold/count/payload）
# AIADS_BUDGET_ALERT_WEBHOOK_URL=https://hooks.slack.com/services/...
