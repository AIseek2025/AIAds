import React, { useState, useEffect } from 'react';
import { useQuery, useMutation, useQueryClient } from '@tanstack/react-query';
import { adminSettingsAPI } from '../../services/adminApi';
import type { SystemSettings, AdminRoleDefinition, AuditLog, SensitiveWord, SystemMonitor, BackupRecord } from '../../types';

// MUI Components
import Box from '@mui/material/Box';
import Typography from '@mui/material/Typography';
import Card from '@mui/material/Card';
import CardContent from '@mui/material/CardContent';
import CardHeader from '@mui/material/CardHeader';
import Table from '@mui/material/Table';
import TableBody from '@mui/material/TableBody';
import TableCell from '@mui/material/TableCell';
import TableContainer from '@mui/material/TableContainer';
import TableHead from '@mui/material/TableHead';
import TablePagination from '@mui/material/TablePagination';
import TableRow from '@mui/material/TableRow';
import TextField from '@mui/material/TextField';
import InputAdornment from '@mui/material/InputAdornment';
import IconButton from '@mui/material/IconButton';
import Button from '@mui/material/Button';
import Chip from '@mui/material/Chip';
import Select, { SelectChangeEvent } from '@mui/material/Select';
import MenuItem from '@mui/material/MenuItem';
import FormControl from '@mui/material/FormControl';
import InputLabel from '@mui/material/InputLabel';
import Dialog from '@mui/material/Dialog';
import DialogTitle from '@mui/material/DialogTitle';
import DialogContent from '@mui/material/DialogContent';
import DialogActions from '@mui/material/DialogActions';
import Avatar from '@mui/material/Avatar';
import Tooltip from '@mui/material/Tooltip';
import CircularProgress from '@mui/material/CircularProgress';
import Alert from '@mui/material/Alert';
import Snackbar from '@mui/material/Snackbar';
import Stack from '@mui/material/Stack';
import Paper from '@mui/material/Paper';
import Tabs from '@mui/material/Tabs';
import Tab from '@mui/material/Tab';
import Grid from '@mui/material/Grid';
import Divider from '@mui/material/Divider';
import List from '@mui/material/List';
import ListItem from '@mui/material/ListItem';
import ListItemText from '@mui/material/ListItemText';
import Switch from '@mui/material/Switch';
import FormControlLabel from '@mui/material/FormControlLabel';
import LinearProgress from '@mui/material/LinearProgress';
import Slider from '@mui/material/Slider';
import InputLabel as MuiInputLabel;

// Icons
import SearchIcon from '@mui/icons-material/Search';
import SaveIcon from '@mui/icons-material/Save';
import AddIcon from '@mui/icons-material/Add';
import EditIcon from '@mui/icons-material/Edit';
import DeleteIcon from '@mui/icons-material/Delete';
import RefreshIcon from '@mui/icons-material/Refresh';
import SettingsIcon from '@mui/icons-material/Settings';
import SecurityIcon from '@mui/icons-material/Security';
import PeopleIcon from '@mui/icons-material/People';
import BadgeIcon from '@mui/icons-material/Badge';
import DescriptionIcon from '@mui/icons-material/Description';
import DownloadIcon from '@mui/icons-material/Download';
import BlockIcon from '@mui/icons-material/Block';
import WarningIcon from '@mui/icons-material/Warning';
import MonitorIcon from '@mui/icons-material/Computer';
import StorageIcon from '@mui/icons-material/Storage';
import BackupIcon from '@mui/icons-material/Backup';
import CloudDownloadIcon from '@mui/icons-material/CloudDownload';
import CheckCircleIcon from '@mui/icons-material/CheckCircle';
import ErrorIcon from '@mui/icons-material/Error';

interface TabPanelProps {
  children?: React.ReactNode;
  index: number;
  value: number;
}

const TabPanel: React.FC<TabPanelProps> = ({ children, value, index, ...other }) => {
  return (
    <div
      role="tabpanel"
      hidden={value !== index}
      id={`settings-tabpanel-${index}`}
      {...other}
    >
      {value === index && <Box sx={{ pt: 3 }}>{children}</Box>}
    </div>
  );
};

const SettingsAdvancedPage: React.FC = () => {
  const queryClient = useQueryClient();

  // State
  const [tabValue, setTabValue] = useState(0);
  const [page, setPage] = useState(0);
  const [pageSize, setPageSize] = useState(20);
  const [keyword, setKeyword] = useState('');
  const [settings, setSettings] = useState<Partial<SystemSettings>>({
    platform: {
      name: 'AIAds',
      logoUrl: '',
      supportEmail: 'support@aiads.com',
      maintenanceMode: false,
    },
    commission: {
      defaultRate: 0.1,
      minRate: 0.05,
      maxRate: 0.2,
    },
    withdrawal: {
      minAmount: 100,
      maxAmount: 100000,
      processingDays: 3,
      autoApproveThreshold: 1000,
    },
  });
  const [selectedRole, setSelectedRole] = useState<AdminRoleDefinition | null>(null);
  const [roleDialogOpen, setRoleDialogOpen] = useState(false);
  const [adminDialogOpen, setAdminDialogOpen] = useState(false);
  const [sensitiveWordDialogOpen, setSensitiveWordDialogOpen] = useState(false);
  const [newSensitiveWord, setNewSensitiveWord] = useState('');
  const [sensitiveWordCategory, setSensitiveWordCategory] = useState<string>('custom');
  const [sensitiveWordAction, setSensitiveWordAction] = useState<string>('block');
  const [selectedLogs, setSelectedLogs] = useState<string[]>([]);
  const [backupDialogOpen, setBackupDialogOpen] = useState(false);
  const [backupType, setBackupType] = useState<'full' | 'incremental' | 'database' | 'files'>('database');
  const [snackbar, setSnackbar] = useState<{ open: boolean; message: string; severity: 'success' | 'error' }>({
    open: false,
    message: '',
    severity: 'success',
  });

  // Fetch settings
  const { data: settingsData, isLoading: settingsLoading } = useQuery({
    queryKey: ['adminSettings'],
    queryFn: () => adminSettingsAPI.getSettings(),
  });

  // Fetch roles
  const { data: roles } = useQuery({
    queryKey: ['adminRoles'],
    queryFn: () => adminSettingsAPI.getRoles(),
  });

  // Fetch audit logs
  const { data: auditLogs, isLoading: logsLoading } = useQuery({
    queryKey: ['adminAuditLogs', page, pageSize],
    queryFn: () => adminSettingsAPI.getAuditLogs({ page: page + 1, page_size: pageSize }),
  });

  // Fetch admins
  const { data: admins } = useQuery({
    queryKey: ['adminAdmins'],
    queryFn: () => adminSettingsAPI.getAdmins(),
  });

  // Fetch sensitive words
  const { data: sensitiveWords } = useQuery({
    queryKey: ['adminSensitiveWords'],
    queryFn: () => adminSettingsAPI.getSensitiveWords({ page: 1, page_size: 100 }),
  });

  // Fetch system monitor
  const { data: systemMonitor, isLoading: monitorLoading } = useQuery({
    queryKey: ['adminSystemMonitor'],
    queryFn: () => adminSettingsAPI.getSystemMonitor(),
    refetchInterval: 30000, // Refresh every 30 seconds
  });

  // Fetch backup records
  const { data: backupRecords } = useQuery({
    queryKey: ['adminBackupRecords'],
    queryFn: () => adminSettingsAPI.getBackupRecords({ page: 1, page_size: 20 }),
  });

  // Update settings mutation
  const updateSettingsMutation = useMutation({
    mutationFn: (data: Partial<SystemSettings>) => adminSettingsAPI.updateSettings(data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['adminSettings'] });
      setSnackbar({ open: true, message: '设置已保存', severity: 'success' });
    },
    onError: (err: any) => {
      setSnackbar({ open: true, message: err.response?.data?.error?.message || '保存失败', severity: 'error' });
    },
  });

  // Create role mutation
  const createRoleMutation = useMutation({
    mutationFn: (data: { name: string; description: string; permissions: string[] }) =>
      adminSettingsAPI.createRole(data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['adminRoles'] });
      setSnackbar({ open: true, message: '角色创建成功', severity: 'success' });
      setRoleDialogOpen(false);
    },
    onError: (err: any) => {
      setSnackbar({ open: true, message: err.response?.data?.error?.message || '创建失败', severity: 'error' });
    },
  });

  // Add sensitive word mutation
  const addSensitiveWordMutation = useMutation({
    mutationFn: (data: { word: string; category: string; severity: string; action: string }) =>
      adminSettingsAPI.addSensitiveWord(data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['adminSensitiveWords'] });
      setSnackbar({ open: true, message: '敏感词添加成功', severity: 'success' });
      setSensitiveWordDialogOpen(false);
      setNewSensitiveWord('');
    },
    onError: (err: any) => {
      setSnackbar({ open: true, message: err.response?.data?.error?.message || '添加失败', severity: 'error' });
    },
  });

  // Delete sensitive word mutation
  const deleteSensitiveWordMutation = useMutation({
    mutationFn: (id: string) => adminSettingsAPI.deleteSensitiveWord(id),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['adminSensitiveWords'] });
      setSnackbar({ open: true, message: '敏感词删除成功', severity: 'success' });
    },
    onError: (err: any) => {
      setSnackbar({ open: true, message: err.response?.data?.error?.message || '删除失败', severity: 'error' });
    },
  });

  // Create backup mutation
  const createBackupMutation = useMutation({
    mutationFn: (data: { type: 'full' | 'incremental' | 'database' | 'files' }) =>
      adminSettingsAPI.createBackup(data),
    onSuccess: () => {
      queryClient.invalidateQueries({ queryKey: ['adminBackupRecords'] });
      setSnackbar({ open: true, message: '备份任务已创建', severity: 'success' });
      setBackupDialogOpen(false);
    },
    onError: (err: any) => {
      setSnackbar({ open: true, message: err.response?.data?.error?.message || '创建失败', severity: 'error' });
    },
  });

  // Handlers
  const handleTabChange = (event: React.SyntheticEvent, newValue: number) => {
    setTabValue(newValue);
  };

  const handleSettingsChange = (section: keyof SystemSettings, key: string, value: any) => {
    setSettings((prev) => ({
      ...prev,
      [section]: {
        ...(prev as any)[section],
        [key]: value,
      },
    }));
  };

  const handleSaveSettings = () => {
    updateSettingsMutation.mutate(settings);
  };

  const handlePageChange = (event: unknown, newPage: number) => {
    setPage(newPage);
  };

  const handlePageSizeChange = (e: React.ChangeEvent<HTMLInputElement>) => {
    setPageSize(parseInt(e.target.value, 10));
    setPage(0);
  };

  const handleSearch = (e: React.ChangeEvent<HTMLInputElement>) => {
    setKeyword(e.target.value);
    setPage(0);
  };

  const handleCloseSnackbar = () => {
    setSnackbar({ ...snackbar, open: false });
  };

  const handleAddSensitiveWord = () => {
    if (!newSensitiveWord) {
      setSnackbar({ open: true, message: '请填写敏感词', severity: 'error' });
      return;
    }
    addSensitiveWordMutation.mutate({
      word: newSensitiveWord,
      category: sensitiveWordCategory,
      severity: 'medium',
      action: sensitiveWordAction,
    });
  };

  const handleDeleteSensitiveWord = (id: string) => {
    if (window.confirm('确定要删除这个敏感词吗？')) {
      deleteSensitiveWordMutation.mutate(id);
    }
  };

  const handleCreateBackup = () => {
    createBackupMutation.mutate({ type: backupType });
  };

  const handleExportLogs = () => {
    setSnackbar({ open: true, message: '日志导出功能开发中', severity: 'info' });
  };

  // Permission categories
  const permissionCategories = [
    {
      category: '用户管理',
      permissions: ['user:view', 'user:create', 'user:edit', 'user:delete', 'user:ban', 'user:unban'],
    },
    {
      category: 'KOL 管理',
      permissions: ['kol:view', 'kol:review', 'kol:approve', 'kol:reject', 'kol:suspend'],
    },
    {
      category: '内容审核',
      permissions: ['content:view', 'content:review', 'content:approve', 'content:reject', 'content:delete'],
    },
    {
      category: '财务管理',
      permissions: ['finance:view', 'finance:export', 'withdrawal:review', 'withdrawal:approve', 'withdrawal:reject'],
    },
    {
      category: '系统设置',
      permissions: ['settings:view', 'settings:edit', 'role:manage', 'admin:manage', 'audit:view'],
    },
  ];

  // Format bytes
  const formatBytes = (bytes: number) => {
    if (bytes === 0) return '0 B';
    const k = 1024;
    const sizes = ['B', 'KB', 'MB', 'GB', 'TB'];
    const i = Math.floor(Math.log(bytes) / Math.log(k));
    return Math.round(bytes / Math.pow(k, i) * 100) / 100 + ' ' + sizes[i];
  };

  return (
    <Box>
      {/* Page Header */}
      <Box sx={{ mb: 4 }}>
        <Typography variant="h4" fontWeight="bold" gutterBottom>
          系统设置（高级）
        </Typography>
        <Typography variant="body2" color="text.secondary">
          管理系统配置、管理员、角色权限、敏感词、系统监控和备份
        </Typography>
      </Box>

      {/* Tabs */}
      <Paper sx={{ mb: 3 }}>
        <Tabs value={tabValue} onChange={handleTabChange} variant="scrollable" scrollButtons="auto">
          <Tab label="系统配置" icon={<SettingsIcon />} iconPosition="start" />
          <Tab label="管理员管理" icon={<PeopleIcon />} iconPosition="start" />
          <Tab label="角色权限" icon={<BadgeIcon />} iconPosition="start" />
          <Tab label="敏感词管理" icon={<BlockIcon />} iconPosition="start" />
          <Tab label="操作日志" icon={<DescriptionIcon />} iconPosition="start" />
          <Tab label="系统监控" icon={<MonitorIcon />} iconPosition="start" />
          <Tab label="备份管理" icon={<BackupIcon />} iconPosition="start" />
        </Tabs>
      </Paper>

      {/* Tab Panel 0 - System Settings */}
      <TabPanel value={tabValue} index={0}>
        <Grid container spacing={3}>
          <Grid size={{ xs: 12, md: 6 }}>
            <Card>
              <CardHeader title="基本设置" />
              <CardContent>
                <Stack spacing={3}>
                  <TextField
                    fullWidth
                    label="平台名称"
                    value={settings.platform?.name}
                    onChange={(e) => handleSettingsChange('platform', 'name', e.target.value)}
                    size="small"
                  />
                  <TextField
                    fullWidth
                    label="支持邮箱"
                    value={settings.platform?.supportEmail}
                    onChange={(e) => handleSettingsChange('platform', 'supportEmail', e.target.value)}
                    size="small"
                  />
                  <TextField
                    fullWidth
                    label="Logo URL"
                    value={settings.platform?.logoUrl}
                    onChange={(e) => handleSettingsChange('platform', 'logoUrl', e.target.value)}
                    size="small"
                    placeholder="https://..."
                  />
                </Stack>
              </CardContent>
            </Card>
          </Grid>

          <Grid size={{ xs: 12, md: 6 }}>
            <Card>
              <CardHeader title="功能开关" />
              <CardContent>
                <Stack spacing={2}>
                  <FormControlLabel
                    control={
                      <Switch
                        checked={settings.platform?.maintenanceMode || false}
                        onChange={(e) => handleSettingsChange('platform', 'maintenanceMode', e.target.checked)}
                      />
                    }
                    label="维护模式"
                  />
                  {settings.platform?.maintenanceMode && (
                    <TextField
                      fullWidth
                      label="维护提示信息"
                      defaultValue="系统维护中，请稍后再试"
                      size="small"
                      multiline
                      rows={2}
                    />
                  )}
                </Stack>
              </CardContent>
            </Card>

            <Card sx={{ mt: 3 }}>
              <CardHeader title="佣金设置" />
              <CardContent>
                <Stack spacing={3}>
                  <Box>
                    <Typography variant="body2" color="text.secondary" gutterBottom>
                      默认佣金比例：{(settings.commission?.defaultRate || 0.1) * 100}%
                    </Typography>
                    <Slider
                      value={(settings.commission?.defaultRate || 0.1) * 100}
                      onChange={(_, value) => handleSettingsChange('commission', 'defaultRate', (value as number) / 100)}
                      min={5}
                      max={20}
                      step={1}
                      valueLabelDisplay="auto"
                      valueLabelFormat={(value) => `${value}%`}
                    />
                  </Box>
                </Stack>
              </CardContent>
            </Card>
          </Grid>

          <Grid size={12}>
            <Box sx={{ display: 'flex', justifyContent: 'flex-end' }}>
              <Button
                variant="contained"
                startIcon={<SaveIcon />}
                onClick={handleSaveSettings}
                disabled={updateSettingsMutation.isPending}
              >
                {updateSettingsMutation.isPending ? <CircularProgress size={24} /> : '保存设置'}
              </Button>
            </Box>
          </Grid>
        </Grid>
      </TabPanel>

      {/* Tab Panel 1 - Admin Management */}
      <TabPanel value={tabValue} index={1}>
        <Card>
          <CardHeader
            title="管理员列表"
            action={
              <Button variant="contained" startIcon={<AddIcon />} onClick={() => setAdminDialogOpen(true)}>
                创建管理员
              </Button>
            }
          />
          <TableContainer>
            <Table>
              <TableHead>
                <TableRow>
                  <TableCell>管理员</TableCell>
                  <TableCell>邮箱</TableCell>
                  <TableCell>角色</TableCell>
                  <TableCell>状态</TableCell>
                  <TableCell>最后登录</TableCell>
                  <TableCell align="right">操作</TableCell>
                </TableRow>
              </TableHead>
              <TableBody>
                {admins?.map((admin) => (
                  <TableRow key={admin.id} hover>
                    <TableCell>
                      <Box sx={{ display: 'flex', alignItems: 'center' }}>
                        <Avatar src={admin.avatarUrl} sx={{ width: 36, height: 36, mr: 1.5 }}>
                          {admin.name[0]}
                        </Avatar>
                        <Typography variant="body2" fontWeight="500">
                          {admin.name}
                        </Typography>
                      </Box>
                    </TableCell>
                    <TableCell>
                      <Typography variant="body2">{admin.email}</Typography>
                    </TableCell>
                    <TableCell>
                      <Chip
                        label={admin.role === 'super_admin' ? '超级管理员' : admin.role === 'admin' ? '管理员' : admin.role}
                        size="small"
                        color={admin.role === 'super_admin' ? 'error' : 'primary'}
                      />
                    </TableCell>
                    <TableCell>
                      <Chip
                        label={admin.status === 'active' ? '正常' : '禁用'}
                        size="small"
                        color={admin.status === 'active' ? 'success' : 'default'}
                        variant={admin.status === 'active' ? 'filled' : 'outlined'}
                      />
                    </TableCell>
                    <TableCell>
                      <Typography variant="body2" color="text.secondary">
                        {admin.lastLoginAt ? new Date(admin.lastLoginAt).toLocaleString('zh-CN') : '从未'}
                      </Typography>
                    </TableCell>
                    <TableCell align="right">
                      <Tooltip title="编辑">
                        <IconButton size="small">
                          <EditIcon fontSize="small" />
                        </IconButton>
                      </Tooltip>
                      <Tooltip title="重置密码">
                        <IconButton size="small" color="warning">
                          <SecurityIcon fontSize="small" />
                        </IconButton>
                      </Tooltip>
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </TableContainer>
        </Card>
      </TabPanel>

      {/* Tab Panel 2 - Role Management */}
      <TabPanel value={tabValue} index={2}>
        <Grid container spacing={3}>
          <Grid size={{ xs: 12, md: 4 }}>
            <Card>
              <CardHeader
                title="角色列表"
                action={
                  <IconButton onClick={() => setRoleDialogOpen(true)}>
                    <AddIcon fontSize="small" />
                  </IconButton>
                }
              />
              <List>
                {roles?.map((role) => (
                  <ListItem
                    key={role.id}
                    button
                    selected={selectedRole?.id === role.id}
                    onClick={() => setSelectedRole(role)}
                    sx={{
                      border: 1,
                      borderColor: selectedRole?.id === role.id ? 'primary.main' : 'divider',
                      borderRadius: 1,
                      mb: 1,
                    }}
                  >
                    <ListItemText
                      primary={role.name}
                      secondary={`${role.permissions?.length || 0} 个权限`}
                    />
                  </ListItem>
                ))}
              </List>
            </Card>
          </Grid>

          <Grid size={{ xs: 12, md: 8 }}>
            <Card>
              <CardHeader title="权限配置" />
              <CardContent>
                {selectedRole ? (
                  <Stack spacing={3}>
                    <TextField
                      fullWidth
                      label="角色名称"
                      value={selectedRole.name}
                      size="small"
                      InputProps={{ readOnly: true }}
                    />
                    <TextField
                      fullWidth
                      label="描述"
                      value={selectedRole.description}
                      size="small"
                      multiline
                      rows={2}
                      InputProps={{ readOnly: true }}
                    />
                    <Divider />
                    <Typography variant="subtitle2" fontWeight="bold">
                      权限列表
                    </Typography>
                    {permissionCategories.map((category) => (
                      <Box key={category.category}>
                        <Typography variant="body2" fontWeight="bold" gutterBottom sx={{ mt: 2 }}>
                          {category.category}
                        </Typography>
                        <Stack direction="row" spacing={1} flexWrap="wrap" useFlexGap>
                          {category.permissions.map((permission) => (
                            <Chip
                              key={permission}
                              label={permission}
                              size="small"
                              color={selectedRole.permissions?.includes(permission) ? 'primary' : 'default'}
                              variant={selectedRole.permissions?.includes(permission) ? 'filled' : 'outlined'}
                            />
                          ))}
                        </Stack>
                      </Box>
                    ))}
                  </Stack>
                ) : (
                  <Typography variant="body2" color="text.secondary" textAlign="center" py={4}>
                    请选择一个角色查看详情
                  </Typography>
                )}
              </CardContent>
            </Card>
          </Grid>
        </Grid>
      </TabPanel>

      {/* Tab Panel 3 - Sensitive Words */}
      <TabPanel value={tabValue} index={3}>
        <Card sx={{ mb: 3 }}>
          <CardContent>
            <Stack direction="row" spacing={2} sx={{ alignItems: 'center' }}>
              <TextField
                placeholder="添加敏感词..."
                value={newSensitiveWord}
                onChange={(e) => setNewSensitiveWord(e.target.value)}
                size="small"
                sx={{ flex: 1 }}
                onKeyPress={(e) => e.key === 'Enter' && handleAddSensitiveWord()}
              />
              <FormControl size="small" sx={{ minWidth: 120 }}>
                <InputLabel>分类</InputLabel>
                <Select
                  value={sensitiveWordCategory}
                  label="分类"
                  onChange={(e) => setSensitiveWordCategory(e.target.value)}
                >
                  <MenuItem value="political">政治</MenuItem>
                  <MenuItem value="pornographic">色情</MenuItem>
                  <MenuItem value="violent">暴力</MenuItem>
                  <MenuItem value="spam">垃圾广告</MenuItem>
                  <MenuItem value="custom">自定义</MenuItem>
                </Select>
              </FormControl>
              <FormControl size="small" sx={{ minWidth: 120 }}>
                <InputLabel>处理</InputLabel>
                <Select
                  value={sensitiveWordAction}
                  label="处理"
                  onChange={(e) => setSensitiveWordAction(e.target.value)}
                >
                  <MenuItem value="block">拦截</MenuItem>
                  <MenuItem value="review">审核</MenuItem>
                  <MenuItem value="warn">警告</MenuItem>
                </Select>
              </FormControl>
              <Button
                variant="contained"
                startIcon={<AddIcon />}
                onClick={handleAddSensitiveWord}
                disabled={addSensitiveWordMutation.isPending || !newSensitiveWord}
              >
                添加
              </Button>
            </Stack>
          </CardContent>
        </Card>

        <Card>
          <TableContainer>
            <Table>
              <TableHead>
                <TableRow>
                  <TableCell>敏感词</TableCell>
                  <TableCell>分类</TableCell>
                  <TableCell>处理方式</TableCell>
                  <TableCell>状态</TableCell>
                  <TableCell>更新时间</TableCell>
                  <TableCell align="right">操作</TableCell>
                </TableRow>
              </TableHead>
              <TableBody>
                {sensitiveWords?.items.map((word) => (
                  <TableRow key={word.id} hover>
                    <TableCell>
                      <Typography variant="body2" fontWeight="500">{word.word}</Typography>
                    </TableCell>
                    <TableCell>
                      <Chip
                        label={word.category === 'political' ? '政治' : word.category === 'pornographic' ? '色情' : word.category === 'violent' ? '暴力' : word.category === 'spam' ? '垃圾广告' : '自定义'}
                        size="small"
                        color={word.category === 'political' || word.category === 'violent' ? 'error' : 'warning'}
                      />
                    </TableCell>
                    <TableCell>
                      <Chip
                        label={word.action === 'block' ? '拦截' : word.action === 'review' ? '审核' : '警告'}
                        size="small"
                        variant="outlined"
                      />
                    </TableCell>
                    <TableCell>
                      <Chip
                        label={word.enabled ? '启用' : '禁用'}
                        size="small"
                        color={word.enabled ? 'success' : 'default'}
                      />
                    </TableCell>
                    <TableCell>
                      <Typography variant="body2" color="text.secondary">
                        {new Date(word.updatedAt).toLocaleDateString('zh-CN')}
                      </Typography>
                    </TableCell>
                    <TableCell align="right">
                      <Tooltip title="删除">
                        <IconButton
                          size="small"
                          color="error"
                          onClick={() => handleDeleteSensitiveWord(word.id)}
                        >
                          <DeleteIcon fontSize="small" />
                        </IconButton>
                      </Tooltip>
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </TableContainer>
        </Card>
      </TabPanel>

      {/* Tab Panel 4 - Audit Logs */}
      <TabPanel value={tabValue} index={4}>
        <Card>
          <CardHeader
            title="操作审计日志"
            action={
              <Stack direction="row" spacing={1}>
                <TextField
                  placeholder="搜索操作内容..."
                  value={keyword}
                  onChange={handleSearch}
                  size="small"
                  sx={{ width: 240 }}
                  InputProps={{
                    startAdornment: (
                      <InputAdornment position="start">
                        <SearchIcon fontSize="small" />
                      </InputAdornment>
                    ),
                  }}
                />
                <Button
                  variant="outlined"
                  startIcon={<DownloadIcon />}
                  onClick={handleExportLogs}
                >
                  导出日志
                </Button>
              </Stack>
            }
          />
          <TableContainer>
            <Table>
              <TableHead>
                <TableRow>
                  <TableCell>时间</TableCell>
                  <TableCell>操作人</TableCell>
                  <TableCell>操作类型</TableCell>
                  <TableCell>操作内容</TableCell>
                  <TableCell>IP 地址</TableCell>
                  <TableCell>状态</TableCell>
                </TableRow>
              </TableHead>
              <TableBody>
                {logsLoading ? (
                  Array.from({ length: 5 }).map((_, index) => (
                    <TableRow key={index}>
                      <TableCell><CircularProgress size={20} /></TableCell>
                      <TableCell><CircularProgress size={20} /></TableCell>
                      <TableCell><CircularProgress size={20} /></TableCell>
                      <TableCell><CircularProgress size={20} /></TableCell>
                      <TableCell><CircularProgress size={20} /></TableCell>
                      <TableCell><CircularProgress size={20} /></TableCell>
                    </TableRow>
                  ))
                ) : auditLogs?.items.length === 0 ? (
                  <TableRow>
                    <TableCell colSpan={6} align="center">
                      <Typography color="text.secondary" py={4}>暂无日志</Typography>
                    </TableCell>
                  </TableRow>
                ) : (
                  auditLogs.items.map((log) => (
                    <TableRow key={log.id} hover>
                      <TableCell>
                        <Typography variant="body2">
                          {log.createdAt ? new Date(log.createdAt).toLocaleString('zh-CN') : '-'}
                        </Typography>
                      </TableCell>
                      <TableCell>
                        <Box sx={{ display: 'flex', alignItems: 'center' }}>
                          <Avatar src={log.admin?.avatarUrl} sx={{ width: 28, height: 28, mr: 1 }}>
                            {log.admin?.name?.[0] || 'A'}
                          </Avatar>
                          <Typography variant="body2">{log.admin?.name || '系统'}</Typography>
                        </Box>
                      </TableCell>
                      <TableCell>
                        <Chip
                          label={log.action}
                          size="small"
                          color="primary"
                          variant="outlined"
                        />
                      </TableCell>
                      <TableCell>
                        <Typography variant="body2" noWrap sx={{ maxWidth: 300 }}>
                          {log.resourceName}
                        </Typography>
                      </TableCell>
                      <TableCell>
                        <Typography variant="body2" color="text.secondary">
                          {log.ipAddress}
                        </Typography>
                      </TableCell>
                      <TableCell>
                        <Chip
                          label={log.status === 'success' ? '成功' : '失败'}
                          size="small"
                          color={log.status === 'success' ? 'success' : 'error'}
                        />
                      </TableCell>
                    </TableRow>
                  ))
                )}
              </TableBody>
            </Table>
          </TableContainer>
          <TablePagination
            component="div"
            count={auditLogs?.pagination.total || 0}
            page={page}
            onPageChange={handlePageChange}
            rowsPerPage={pageSize}
            onRowsPerPageChange={handlePageSizeChange}
            rowsPerPageOptions={[10, 20, 50, 100]}
          />
        </Card>
      </TabPanel>

      {/* Tab Panel 5 - System Monitor */}
      <TabPanel value={tabValue} index={5}>
        <Grid container spacing={3}>
          {/* CPU */}
          <Grid size={{ xs: 12, md: 6 }}>
            <Card>
              <CardHeader title="CPU 使用率" icon={<MonitorIcon />} />
              <CardContent>
                {monitorLoading || !systemMonitor ? (
                  <CircularProgress />
                ) : (
                  <Box>
                    <Box sx={{ display: 'flex', justifyContent: 'space-between', mb: 1 }}>
                      <Typography variant="body2">使用率</Typography>
                      <Typography variant="body2" fontWeight="bold">
                        {systemMonitor.cpu.usage.toFixed(1)}%
                      </Typography>
                    </Box>
                    <LinearProgress
                      variant="determinate"
                      value={systemMonitor.cpu.usage}
                      color={systemMonitor.cpu.usage > 80 ? 'error' : systemMonitor.cpu.usage > 60 ? 'warning' : 'success'}
                    />
                    <Typography variant="caption" color="text.secondary" sx={{ mt: 1 }}>
                      {systemMonitor.cpu.cores} 核心
                    </Typography>
                  </Box>
                )}
              </CardContent>
            </Card>
          </Grid>

          {/* Memory */}
          <Grid size={{ xs: 12, md: 6 }}>
            <Card>
              <CardHeader title="内存使用" icon={<StorageIcon />} />
              <CardContent>
                {monitorLoading || !systemMonitor ? (
                  <CircularProgress />
                ) : (
                  <Box>
                    <Box sx={{ display: 'flex', justifyContent: 'space-between', mb: 1 }}>
                      <Typography variant="body2">使用率</Typography>
                      <Typography variant="body2" fontWeight="bold">
                        {systemMonitor.memory.usage.toFixed(1)}%
                      </Typography>
                    </Box>
                    <LinearProgress
                      variant="determinate"
                      value={systemMonitor.memory.usage}
                      color={systemMonitor.memory.usage > 80 ? 'error' : systemMonitor.memory.usage > 60 ? 'warning' : 'success'}
                    />
                    <Typography variant="caption" color="text.secondary" sx={{ mt: 1 }}>
                      {formatBytes(systemMonitor.memory.used)} / {formatBytes(systemMonitor.memory.total)}
                    </Typography>
                  </Box>
                )}
              </CardContent>
            </Card>
          </Grid>

          {/* Disk */}
          <Grid size={{ xs: 12, md: 6 }}>
            <Card>
              <CardHeader title="磁盘使用" icon={<StorageIcon />} />
              <CardContent>
                {monitorLoading || !systemMonitor ? (
                  <CircularProgress />
                ) : (
                  <Box>
                    <Box sx={{ display: 'flex', justifyContent: 'space-between', mb: 1 }}>
                      <Typography variant="body2">使用率</Typography>
                      <Typography variant="body2" fontWeight="bold">
                        {systemMonitor.disk.usage.toFixed(1)}%
                      </Typography>
                    </Box>
                    <LinearProgress
                      variant="determinate"
                      value={systemMonitor.disk.usage}
                      color={systemMonitor.disk.usage > 80 ? 'error' : systemMonitor.disk.usage > 60 ? 'warning' : 'success'}
                    />
                    <Typography variant="caption" color="text.secondary" sx={{ mt: 1 }}>
                      {formatBytes(systemMonitor.disk.used)} / {formatBytes(systemMonitor.disk.total)}
                    </Typography>
                  </Box>
                )}
              </CardContent>
            </Card>
          </Grid>

          {/* Database */}
          <Grid size={{ xs: 12, md: 6 }}>
            <Card>
              <CardHeader title="数据库" icon={<StorageIcon />} />
              <CardContent>
                {monitorLoading || !systemMonitor ? (
                  <CircularProgress />
                ) : (
                  <Stack spacing={2}>
                    <Box>
                      <Box sx={{ display: 'flex', justifyContent: 'space-between', mb: 1 }}>
                        <Typography variant="body2">连接数</Typography>
                        <Typography variant="body2" fontWeight="bold">
                          {systemMonitor.database.connections} / {systemMonitor.database.maxConnections}
                        </Typography>
                      </Box>
                      <LinearProgress
                        variant="determinate"
                        value={(systemMonitor.database.connections / systemMonitor.database.maxConnections) * 100}
                      />
                    </Box>
                    <Box sx={{ display: 'flex', justifyContent: 'space-between' }}>
                      <Typography variant="body2" color="text.secondary">查询/秒</Typography>
                      <Typography variant="body2" fontWeight="bold">
                        {systemMonitor.database.queriesPerSecond}
                      </Typography>
                    </Box>
                  </Stack>
                )}
              </CardContent>
            </Card>
          </Grid>

          {/* Cache */}
          <Grid size={{ xs: 12, md: 6 }}>
            <Card>
              <CardHeader title="缓存" icon={<StorageIcon />} />
              <CardContent>
                {monitorLoading || !systemMonitor ? (
                  <CircularProgress />
                ) : (
                  <Stack spacing={2}>
                    <Box sx={{ display: 'flex', justifyContent: 'space-between' }}>
                      <Typography variant="body2">命中率</Typography>
                      <Typography variant="body2" fontWeight="bold" color="success.main">
                        {(systemMonitor.cache.hitRate * 100).toFixed(1)}%
                      </Typography>
                    </Box>
                    <Box sx={{ display: 'flex', justifyContent: 'space-between' }}>
                      <Typography variant="body2" color="text.secondary">内存使用</Typography>
                      <Typography variant="body2" fontWeight="bold">
                        {formatBytes(systemMonitor.cache.memoryUsed)}
                      </Typography>
                    </Box>
                    <Box sx={{ display: 'flex', justifyContent: 'space-between' }}>
                      <Typography variant="body2" color="text.secondary">键数量</Typography>
                      <Typography variant="body2" fontWeight="bold">
                        {systemMonitor.cache.keysCount}
                      </Typography>
                    </Box>
                  </Stack>
                )}
              </CardContent>
            </Card>
          </Grid>

          {/* Queue */}
          <Grid size={{ xs: 12, md: 6 }}>
            <Card>
              <CardHeader title="任务队列" icon={<StorageIcon />} />
              <CardContent>
                {monitorLoading || !systemMonitor ? (
                  <CircularProgress />
                ) : (
                  <Grid container spacing={2}>
                    <Grid size={4}>
                      <Box sx={{ textAlign: 'center', p: 2, bgcolor: 'warning.lighter', borderRadius: 2 }}>
                        <Typography variant="h6" fontWeight="bold" color="warning.main">
                          {systemMonitor.queue.pending}
                        </Typography>
                        <Typography variant="caption" color="text.secondary">待处理</Typography>
                      </Box>
                    </Grid>
                    <Grid size={4}>
                      <Box sx={{ textAlign: 'center', p: 2, bgcolor: 'info.lighter', borderRadius: 2 }}>
                        <Typography variant="h6" fontWeight="bold" color="info.main">
                          {systemMonitor.queue.processing}
                        </Typography>
                        <Typography variant="caption" color="text.secondary">处理中</Typography>
                      </Box>
                    </Grid>
                    <Grid size={4}>
                      <Box sx={{ textAlign: 'center', p: 2, bgcolor: 'error.lighter', borderRadius: 2 }}>
                        <Typography variant="h6" fontWeight="bold" color="error.main">
                          {systemMonitor.queue.failed}
                        </Typography>
                        <Typography variant="caption" color="text.secondary">失败</Typography>
                      </Box>
                    </Grid>
                  </Grid>
                )}
              </CardContent>
            </Card>
          </Grid>
        </Grid>
      </TabPanel>

      {/* Tab Panel 6 - Backup Management */}
      <TabPanel value={tabValue} index={6}>
        <Box sx={{ mb: 3 }}>
          <Button
            variant="contained"
            startIcon={<BackupIcon />}
            onClick={() => setBackupDialogOpen(true)}
          >
            创建备份
          </Button>
        </Box>

        <Card>
          <TableContainer>
            <Table>
              <TableHead>
                <TableRow>
                  <TableCell>备份类型</TableCell>
                  <TableCell>状态</TableCell>
                  <TableCell>大小</TableCell>
                  <TableCell>开始时间</TableCell>
                  <TableCell>完成时间</TableCell>
                  <TableCell align="right">操作</TableCell>
                </TableRow>
              </TableHead>
              <TableBody>
                {backupRecords?.items.map((backup) => (
                  <TableRow key={backup.id} hover>
                    <TableCell>
                      <Chip
                        label={backup.type === 'full' ? '完整备份' : backup.type === 'incremental' ? '增量备份' : backup.type === 'database' ? '数据库备份' : '文件备份'}
                        size="small"
                        color="primary"
                        variant="outlined"
                      />
                    </TableCell>
                    <TableCell>
                      <Chip
                        label={backup.status === 'completed' ? '已完成' : backup.status === 'in_progress' ? '进行中' : backup.status === 'failed' ? '失败' : '待处理'}
                        size="small"
                        color={backup.status === 'completed' ? 'success' : backup.status === 'in_progress' ? 'info' : backup.status === 'failed' ? 'error' : 'warning'}
                        icon={backup.status === 'completed' ? <CheckCircleIcon /> : backup.status === 'failed' ? <ErrorIcon /> : undefined}
                      />
                    </TableCell>
                    <TableCell>
                      <Typography variant="body2">{formatBytes(backup.size)}</Typography>
                    </TableCell>
                    <TableCell>
                      <Typography variant="body2" color="text.secondary">
                        {new Date(backup.startedAt).toLocaleString('zh-CN')}
                      </Typography>
                    </TableCell>
                    <TableCell>
                      <Typography variant="body2" color="text.secondary">
                        {backup.completedAt ? new Date(backup.completedAt).toLocaleString('zh-CN') : '-'}
                      </Typography>
                    </TableCell>
                    <TableCell align="right">
                      {backup.status === 'completed' && (
                        <Tooltip title="下载">
                          <IconButton size="small" color="primary">
                            <CloudDownloadIcon fontSize="small" />
                          </IconButton>
                        </Tooltip>
                      )}
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </TableContainer>
        </Card>
      </TabPanel>

      {/* Create Backup Dialog */}
      <Dialog open={backupDialogOpen} onClose={() => setBackupDialogOpen(false)} maxWidth="sm" fullWidth>
        <DialogTitle>创建备份</DialogTitle>
        <DialogContent>
          <Box sx={{ pt: 2 }}>
            <Stack spacing={3}>
              <Alert severity="info">
                选择备份类型，系统将自动执行备份任务
              </Alert>
              <FormControl fullWidth>
                <InputLabel>备份类型</InputLabel>
                <Select
                  value={backupType}
                  label="备份类型"
                  onChange={(e) => setBackupType(e.target.value as any)}
                >
                  <MenuItem value="database">数据库备份</MenuItem>
                  <MenuItem value="files">文件备份</MenuItem>
                  <MenuItem value="incremental">增量备份</MenuItem>
                  <MenuItem value="full">完整备份</MenuItem>
                </Select>
              </FormControl>
            </Stack>
          </Box>
        </DialogContent>
        <DialogActions>
          <Button onClick={() => setBackupDialogOpen(false)}>取消</Button>
          <Button
            variant="contained"
            onClick={handleCreateBackup}
            disabled={createBackupMutation.isPending}
          >
            {createBackupMutation.isPending ? <CircularProgress size={24} /> : '开始备份'}
          </Button>
        </DialogActions>
      </Dialog>

      <Snackbar
        open={snackbar.open}
        autoHideDuration={6000}
        onClose={handleCloseSnackbar}
        anchorOrigin={{ vertical: 'bottom', horizontal: 'center' }}
      >
        <Alert onClose={handleCloseSnackbar} severity={snackbar.severity} sx={{ width: '100%' }}>
          {snackbar.message}
        </Alert>
      </Snackbar>
    </Box>
  );
};

export default SettingsAdvancedPage;
