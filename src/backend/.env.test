# Test Environment Configuration
NODE_ENV=test
PORT=3001
LOG_LEVEL=error

# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/aiads_test

# Redis Configuration
REDIS_URL=redis://localhost:6379/1

# JWT Configuration
JWT_SECRET=test_jwt_secret_key_for_unit_testing_purposes_only_12345678
JWT_REFRESH_SECRET=test_jwt_refresh_secret_key_for_unit_testing_purposes_123456
JWT_EXPIRES_IN=1h

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3001

# KOL 接单频控（单测 prisma-memory 不支持 order.count，默认关闭）
KOL_ACCEPT_FREQ_ENABLED=false

# Email Configuration (mocked)
SENDGRID_API_KEY=test-sendgrid-api-key
EMAIL_FROM=noreply@test.aiads.com

# Object Storage (mocked)
R2_ACCOUNT_ID=test-r2-account-id
R2_ACCESS_KEY=test-r2-access-key
R2_SECRET_KEY=test-r2-secret-key
R2_BUCKET=aiads-test-storage
R2_PUBLIC_URL=https://test-cdn.aiads.com

# Payment Configuration (mocked)
ALIPAY_APP_ID=test-alipay-app-id
ALIPAY_PRIVATE_KEY=test-alipay-private-key
ALIPAY_PUBLIC_KEY=test-alipay-public-key
WECHAT_PAY_APP_ID=test-wechat-pay-app-id
WECHAT_PAY_MCH_ID=test-wechat-pay-merchant-id
WECHAT_PAY_API_KEY=test-wechat-pay-api-key
STRIPE_SECRET_KEY=test-stripe-secret-key
STRIPE_WEBHOOK_SECRET=test-stripe-webhook-secret
PAYPAL_CLIENT_ID=test-paypal-client-id
PAYPAL_CLIENT_SECRET=test-paypal-client-secret

# Social Media API Configuration (mocked)
TIKTOK_CLIENT_ID=test-tiktok-client-id
TIKTOK_CLIENT_SECRET=test-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:3001/api/v1/integrations/tiktok/callback
YOUTUBE_CLIENT_ID=test-youtube-client-id
YOUTUBE_CLIENT_SECRET=test-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3001/api/v1/integrations/youtube/callback
INSTAGRAM_CLIENT_ID=test-instagram-client-id
INSTAGRAM_CLIENT_SECRET=test-instagram-client-secret
INSTAGRAM_REDIRECT_URI=http://localhost:3001/api/v1/integrations/instagram/callback

# Monitoring & Logging (disabled for tests)
SENTRY_DSN=
LOGTAIL_TOKEN=
