# AIAds Backend Environment Configuration
# Copy this file to .env and fill in your values

# ===========================================
# Application Settings
# ===========================================
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ===========================================
# Database Configuration (Supabase PostgreSQL)
# ===========================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@localhost:5432/aiads

# ===========================================
# Redis Configuration (Upstash or local)
# ===========================================
# Format: redis://host:port or rediss://user:password@host:port
REDIS_URL=redis://localhost:6379

# ===========================================
# JWT Configuration
# ===========================================
# IMPORTANT: Use strong, randomly generated secrets (at least 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# DO NOT use default values in production - the application will refuse to start!
JWT_SECRET=97ae6b8bd36bd4949aa0752f1e83786e1d964f3835dbbbc0d3e9731038610da4
JWT_REFRESH_SECRET=031d6a397393730ce2d9a0d09b9a9e4113f6c5099c0c6b4762c9b3e445d8af15
JWT_EXPIRES_IN=1h

# ===========================================
# CORS Configuration
# ===========================================
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===========================================
# CSRF Configuration
# ===========================================
# CSRF protection is enabled by default for state-changing requests
# The CSRF token is retrieved via GET /api/v1/csrf-token
# Include the token in the X-CSRF-Token header for POST/PUT/PATCH/DELETE requests

# ===========================================
# HTTPS Configuration
# ===========================================
# In production (NODE_ENV=production), HTTPS is enforced
# The application will redirect HTTP to HTTPS automatically
# Make sure your reverse proxy sets the X-Forwarded-Proto header

# ===========================================
# Email Configuration (SendGrid)
# ===========================================
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@aiads.com

# ===========================================
# SMS Configuration (Twilio)
# ===========================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ===========================================
# Object Storage (Cloudflare R2)
# ===========================================
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=aiads-storage
R2_PUBLIC_URL=https://cdn.aiads.com

# ===========================================
# Payment Configuration
# ===========================================
# Alipay
ALIPAY_APP_ID=your-alipay-app-id
ALIPAY_PRIVATE_KEY=your-alipay-private-key
ALIPAY_PUBLIC_KEY=your-alipay-public-key

# WeChat Pay
WECHAT_PAY_APP_ID=your-wechat-pay-app-id
WECHAT_PAY_MCH_ID=your-wechat-pay-merchant-id
WECHAT_PAY_API_KEY=your-wechat-pay-api-key

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret

# PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret

# ===========================================
# Social Media API Configuration
# ===========================================
# TikTok
TIKTOK_CLIENT_ID=your-tiktok-client-id
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret
TIKTOK_REDIRECT_URI=http://localhost:3000/api/v1/integrations/tiktok/callback

# YouTube
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/youtube/callback

# Instagram (Facebook App)
INSTAGRAM_CLIENT_ID=your-instagram-client-id
INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/v1/integrations/instagram/callback

# ===========================================
# Monitoring & Logging
# ===========================================
SENTRY_DSN=your-sentry-dsn
LOGTAIL_TOKEN=your-logtail-token

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
