# 复制为 tests/.env 或写在仓库根 .env（global-setup 会先后加载根目录与 tests/.env）
# 管理端 API E2E：至少配置 API_BASE；TOKEN 可省略（若同时配置下方邮箱密码则启动时自动换取）

AIADS_E2E_API_BASE=http://localhost:8080

# 二选一：直接贴长期 Token
# AIADS_E2E_ADMIN_TOKEN=

# 或：用邮箱密码在 global-setup 中换 Token（推荐本地/CI 密钥注入）
AIADS_E2E_ADMIN_EMAIL=admin@example.com
AIADS_E2E_ADMIN_PASSWORD=

# 可选：订单详情用例；不填时若列表有数据会自动取首条订单 ID
# AIADS_E2E_ORDER_ID=

# --- 门户：integration-order-lifecycle-api + role-api-smoke（global-setup 可用邮箱密码换 Token）
# AIADS_E2E_ADVERTISER_EMAIL=
# AIADS_E2E_ADVERTISER_PASSWORD=
# AIADS_E2E_KOL_EMAIL=
# AIADS_E2E_KOL_PASSWORD=
# 可选：直接贴门户 JWT（若已设置则不再用邮箱密码换取）
# AIADS_E2E_ADVERTISER_TOKEN=
# AIADS_E2E_KOL_TOKEN=
