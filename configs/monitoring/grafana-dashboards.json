{
  "dashboard": {
    "id": null,
    "uid": "aiads-production-overview",
    "title": "AIAds Production Dashboard - 100% Traffic",
    "description": "Comprehensive dashboard for monitoring AIAds production environment with 100% traffic",
    "tags": ["aiads", "production", "live"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": ["5s", "10s", "30s", "1m", "5m", "15m", "30m", "1h"]
    },
    "templating": {
      "list": [
        {
          "name": "namespace",
          "type": "query",
          "datasource": "Prometheus",
          "query": "label_values(kube_namespace_labels, namespace)",
          "default": "aiads"
        }
      ]
    },
    "panels": [
      {
        "id": 1,
        "gridPos": {"h": 4, "w": 24, "x": 0, "y": 0},
        "type": "stat",
        "title": "Production Status",
        "targets": [
          {
            "expr": "count(kube_pod_labels{namespace=\"$namespace\", environment=\"production\"})",
            "legendFormat": "Production Pods"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 8},
                {"color": "red", "value": 0}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
        "type": "timeseries",
        "title": "Request Rate (QPS)",
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{environment=\"production\"}[5m]))",
            "legendFormat": "Production QPS",
            "color": "#32CD32"
          }
        ],
        "yAxes": [
          {
            "label": "Requests/sec",
            "min": 0
          }
        ]
      },
      {
        "id": 3,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
        "type": "timeseries",
        "title": "Error Rate (%)",
        "targets": [
          {
            "expr": "sum(rate(http_requests_total{environment=\"production", status=~"5.."}[5m])) / sum(rate(http_requests_total{environment=\"production\"}[5m])) * 100",
            "legendFormat": "Production Error Rate",
            "color": "#32CD32"
          }
        ],
        "yAxes": [
          {
            "label": "Error Rate %",
            "min": 0,
            "max": 5
          }
        ],
        "alert": {
          "name": "Production Error Rate Alert",
          "conditions": [
            {
              "evaluator": {"params": [1], "type": "gt"},
              "operator": {"type": "and"},
              "query": {"params": ["A", "5m", "now"]},
              "reducer": {"type": "avg"}
            }
          ]
        }
      },
      {
        "id": 4,
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 12},
        "type": "timeseries",
        "title": "P50 Latency (ms)",
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{environment=\"production\"}[5m])) by (le)) * 1000",
            "legendFormat": "Production P50",
            "color": "#32CD32"
          }
        ],
        "yAxes": [{"label": "ms", "min": 0}]
      },
      {
        "id": 5,
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 12},
        "type": "timeseries",
        "title": "P95 Latency (ms)",
        "targets": [
          {
            "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{environment=\"production\"}[5m])) by (le)) * 1000",
            "legendFormat": "Production P95",
            "color": "#32CD32"
          }
        ],
        "yAxes": [{"label": "ms", "min": 0}],
        "alert": {
          "name": "Production P95 Latency Alert",
          "conditions": [
            {
              "evaluator": {"params": [150], "type": "gt"},
              "query": {"params": ["A", "5m", "now"]}
            }
          ]
        }
      },
      {
        "id": 6,
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 12},
        "type": "timeseries",
        "title": "P99 Latency (ms)",
        "targets": [
          {
            "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{environment=\"production\"}[5m])) by (le)) * 1000",
            "legendFormat": "Production P99",
            "color": "#32CD32"
          }
        ],
        "yAxes": [{"label": "ms", "min": 0}]
      },
      {
        "id": 7,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
        "type": "timeseries",
        "title": "CPU Usage (%)",
        "targets": [
          {
            "expr": "avg(rate(container_cpu_usage_seconds_total{namespace=\"aiads\", environment=\"production\"}[5m])) * 100",
            "legendFormat": "Production CPU",
            "color": "#32CD32"
          }
        ],
        "yAxes": [{"label": "%", "min": 0, "max": 100}]
      },
      {
        "id": 8,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
        "type": "timeseries",
        "title": "Memory Usage (%)",
        "targets": [
          {
            "expr": "avg(container_memory_usage_bytes{namespace=\"aiads\", environment=\"production\"} / container_spec_memory_limit_bytes{namespace=\"aiads\", environment=\"production\"}) * 100",
            "legendFormat": "Production Memory",
            "color": "#32CD32"
          }
        ],
        "yAxes": [{"label": "%", "min": 0, "max": 100}]
      },
      {
        "id": 9,
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 28},
        "type": "stat",
        "title": "Traffic Share",
        "targets": [
          {
            "expr": "100",
            "legendFormat": "Traffic %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "green", "value": null}
              ]
            },
            "unit": "percent"
          }
        }
      },
      {
        "id": 10,
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 28},
        "type": "stat",
        "title": "Active Users (1h)",
        "targets": [
          {
            "expr": "count(count by (user_id) (http_requests_total{environment=\"production\"}[1h]))",
            "legendFormat": "Users"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        }
      },
      {
        "id": 11,
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 28},
        "type": "stat",
        "title": "Total Requests (24h)",
        "targets": [
          {
            "expr": "sum(increase(http_requests_total{environment=\"production\"}[24h]))",
            "legendFormat": "Requests"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "short"
          }
        }
      },
      {
        "id": 12,
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 28},
        "type": "stat",
        "title": "Avg Response Time",
        "targets": [
          {
            "expr": "avg(rate(http_request_duration_seconds_sum{environment=\"production\"}[5m]) / rate(http_request_duration_seconds_count{environment=\"production\"}[5m])) * 1000",
            "legendFormat": "ms"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "unit": "ms"
          }
        }
      },
      {
        "id": 13,
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 34},
        "type": "table",
        "title": "Top Error Endpoints",
        "targets": [
          {
            "expr": "topk(10, sum by (endpoint) (rate(http_requests_total{environment=\"production\", status=~\"5..\"}[1h])))",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "endpoint": "Endpoint",
                "Value": "Error Count"
              }
            }
          }
        ]
      },
      {
        "id": 14,
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 34},
        "type": "table",
        "title": "Slowest Endpoints",
        "targets": [
          {
            "expr": "topk(10, avg by (endpoint) (rate(http_request_duration_seconds_sum{environment=\"production\"}[5m]) / rate(http_request_duration_seconds_count{environment=\"production\"}[5m])))",
            "format": "table",
            "instant": true
          }
        ],
        "transformations": [
          {
            "id": "organize",
            "options": {
              "renameByName": {
                "endpoint": "Endpoint",
                "Value": "Avg Latency (s)"
              }
            }
          }
        ]
      },
      {
        "id": 15,
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 42},
        "type": "timeseries",
        "title": "Database Connections",
        "targets": [
          {
            "expr": "pg_stat_activity_count{environment=\"production\"}",
            "legendFormat": "Production DB Connections",
            "color": "#32CD32"
          }
        ],
        "yAxes": [{"label": "Connections", "min": 0}]
      },
      {
        "id": 16,
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 50},
        "type": "timeseries",
        "title": "Redis Operations",
        "targets": [
          {
            "expr": "rate(redis_commands_processed_total{environment=\"production\"}[5m])",
            "legendFormat": "Production Redis Ops",
            "color": "#32CD32"
          }
        ],
        "yAxes": [{"label": "Ops/sec", "min": 0}]
      },
      {
        "id": 17,
        "gridPos": {"h": 6, "w": 8, "x": 0, "y": 58},
        "type": "stat",
        "title": "Availability (24h)",
        "targets": [
          {
            "expr": "avg(avg_over_time(up{environment=\"production\"}[24h])) * 100",
            "legendFormat": "Availability %"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "steps": [
                {"color": "red", "value": null},
                {"color": "yellow", "value": 99},
                {"color": "green", "value": 99.9}
              ]
            },
            "unit": "percent"
          }
        }
      },
      {
        "id": 18,
        "gridPos": {"h": 6, "w": 8, "x": 8, "y": 58},
        "type": "stat",
        "title": "Deployment Version",
        "targets": [
          {
            "expr": "label_replace(kube_deployment_labels{deployment=\"aiads-production\"}, \"version\", \"$1\", \"version\", \"(.*)\")",
            "legendFormat": "{{version}}"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "mappings": [
              {"type": "value", "options": {"match": "null", "result": {"text": "v1.3.0"}}}
            ]
          }
        }
      },
      {
        "id": 19,
        "gridPos": {"h": 6, "w": 8, "x": 16, "y": 58},
        "type": "stat",
        "title": "Replicas (Ready/Desired)",
        "targets": [
          {
            "expr": "kube_deployment_status_replicas_available{deployment=\"aiads-production\"}",
            "legendFormat": "Available"
          },
          {
            "expr": "kube_deployment_spec_replicas{deployment=\"aiads-production\"}",
            "legendFormat": "Desired"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"}
          }
        }
      }
    ],
    "annotations": {
      "list": [
        {
          "datasource": "Prometheus",
          "enable": true,
          "expr": "changes(kube_deployment_status_observed_generation{deployment=\"aiads-production\"}[1m]) > 0",
          "iconColor": "yellow",
          "name": "Deployments",
          "titleFormat": "Deployment"
        }
      ]
    },
    "links": [
      {
        "icon": "dashboard",
        "tags": [],
        "targetBlank": true,
        "title": "Kubernetes Dashboard",
        "url": "/d/kubernetes-overview"
      },
      {
        "icon": "doc",
        "tags": [],
        "targetBlank": true,
        "title": "Runbook",
        "url": "https://wiki.aiads.com/runbooks/production-release"
      }
    ]
  }
}
